<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Full-screen map -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════════════════════
         ADDRESS SEARCH / PLANNER CARD — hidden during navigation
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/search_card_bg"
        android:elevation="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

            <!-- Mode toggle -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/modeToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@id/btnModeAddress">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeAddress"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.FietsRouten.Square"
                    android:text="@string/mode_address" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeKnooppunten"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.FietsRouten.Square"
                    android:text="@string/mode_knooppunten" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Address mode content -->
            <LinearLayout
                android:id="@+id/addressModeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="4dp"
                            android:paddingEnd="48dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_marker_origin"
                                android:contentDescription="@null" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_from"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <AutoCompleteTextView
                                    android:id="@+id/actvFrom"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:padding="0dp"
                                    android:textSize="15sp"
                                    android:hint="@string/hint_from"
                                    android:inputType="text"
                                    android:imeOptions="actionNext"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="34dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="4dp"
                            android:paddingEnd="48dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_marginEnd="12dp"
                                android:src="@drawable/ic_marker_destination"
                                android:contentDescription="@null" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_to"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <AutoCompleteTextView
                                    android:id="@+id/actvTo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:padding="0dp"
                                    android:textSize="15sp"
                                    android:hint="@string/hint_to"
                                    android:inputType="text"
                                    android:imeOptions="actionSearch"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnSwap"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="6dp"
                        android:padding="8dp"
                        android:background="@drawable/swap_button_bg"
                        android:foreground="?android:attr/selectableItemBackgroundBorderless"
                        android:elevation="4dp"
                        app:srcCompat="@drawable/ic_swap"
                        android:contentDescription="@string/swap_locations_desc" />

                </FrameLayout>

                <Button
                    android:id="@+id/btnRoute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_find_route" />

            </LinearLayout>

            <!-- Route Plannen mode: city search -->
            <LinearLayout
                android:id="@+id/knooppuntenModeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <AutoCompleteTextView
                    android:id="@+id/actvPlannerCity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:paddingStart="4dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textSize="15sp"
                    android:hint="@string/planner_city_hint"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="12dp"
                    android:singleLine="true" />

            </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════
         NAVIGATION INSTRUCTION BAR — TomTom style, full width
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/navInstructionCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/nav_instruction_bg"
        android:elevation="8dp"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="@drawable/nav_instruction_icon_bg"
            android:gravity="center"
            android:minHeight="90dp">

            <ImageView
                android:id="@+id/ivTurnIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="@string/nav_turn_icon_desc" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCurrentInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvDistanceToTurn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/nav_instruction_next_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_then"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

            <ImageView
                android:id="@+id/ivNextTurnIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:visibility="invisible"
                android:contentDescription="@string/nav_turn_icon_desc" />

        </LinearLayout>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Error message -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/error_red"
        android:visibility="gone"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Cycling routes layer FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabLayers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/fab_layers_desc"
        app:srcCompat="@drawable/ic_layers"
        app:fabSize="mini"
        app:backgroundTint="@color/fab_bg"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- POI along route FAB — only visible when route is active -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPois"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/fab_pois_desc"
        app:srcCompat="@drawable/ic_poi"
        app:fabSize="mini"
        app:backgroundTint="@color/fab_bg"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/fabLayers"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Recenter on my location FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRecenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/fab_recenter_desc"
        app:srcCompat="@android:drawable/ic_menu_mylocation"
        app:tint="@color/brand_primary"
        app:fabSize="mini"
        app:backgroundTint="@color/fab_bg"
        app:layout_constraintTop_toBottomOf="@id/fabPois"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- POI info card — shown when a POI is tapped -->
    <androidx.cardview.widget.CardView
        android:id="@+id/poiInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardElevation="6dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/surface_card_solid"
        app:layout_constraintBottom_toTopOf="@id/instructionsPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPoiName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvPoiType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvPoiClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×"
                android:textSize="20sp"
                android:textColor="@color/text_tertiary"
                android:padding="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════════════════
         ROUTE SUMMARY PANEL — shown after route calculation (both modes)
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/instructionsPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface_card_solid">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <include
                    android:id="@+id/profileSelector"
                    layout="@layout/partial_profile_selector" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textStyle="bold"
                        android:text="@string/distance_placeholder" />

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textStyle="bold"
                        android:text="@string/duration_placeholder" />

                </LinearLayout>

                <com.fietsrouten.ui.ElevationChartView
                    android:id="@+id/elevationChart"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnStartNavigation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_start_navigation" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════
         ROUTE PLANNEN PANEL — vertical node list, ANWB style
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/plannerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface_card_solid">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Scrollable node list -->
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="260dp"
                    android:scrollbars="vertical">

                    <LinearLayout
                        android:id="@+id/llRouteList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </ScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/divider" />

                <!-- Total distance -->
                <TextView
                    android:id="@+id/tvPlannerTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/brand_primary" />

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnClearPlanner"
                        style="@style/Widget.AppCompat.Button.Borderless"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_clear_planner" />

                    <Button
                        android:id="@+id/btnCalculatePlannerRoute"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="@string/btn_calculate_planner_route" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════
         NAVIGATION BOTTOM BAR — dark TomTom-style, shown during nav
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/navBottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bottom_bar_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvNavRemaining"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNavEta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/nav_secondary_text"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/speed_badge_bg"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btnStopNavigation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_stop_navigation"
            android:backgroundTint="@color/error_red"
            android:textColor="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
